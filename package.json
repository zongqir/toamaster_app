{
  "name": "miaoda-taro-react-starter",
  "version": "1.0.0",
  "description": "开箱即用的基于Taro + React + Zustand + TailwindCSS + TypeScript的模板",
  "author": "miaoda-team",
  "license": "MIT",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass"
  },
  "scripts": {
    "dev": "node ./scripts/taro-build.mjs --type h5 --watch",
    "dev:h5": "node ./scripts/taro-build.mjs --type h5 --watch",
    "dev:weapp": "node ./scripts/taro-build.mjs --type weapp --watch",
    "build": "node ./scripts/taro-build.mjs --type h5",
    "build:h5": "node ./scripts/taro-build.mjs --type h5",
    "build:weapp": "node ./scripts/taro-build.mjs --type weapp",
    "postinstall": "weapp-tw patch",
    "lint": "node ./scripts/runLint.mjs"
  },
  "browserslist": [
    "last 5 years",
    "Android >= 9",
    "iOS >= 13",
    "not dead"
  ],
  "dependencies": {
    "@babel/runtime": "^7.28.6",
    "@supabase/supabase-js": "^2.91.1",
    "@tarojs/components": "4.1.10",
    "@tarojs/helper": "4.1.10",
    "@tarojs/plugin-framework-react": "4.1.10",
    "@tarojs/plugin-generator": "4.1.10",
    "@tarojs/plugin-html": "4.1.10",
    "@tarojs/plugin-http": "4.1.10",
    "@tarojs/plugin-platform-h5": "4.1.10",
    "@tarojs/plugin-platform-weapp": "4.1.10",
    "@tarojs/react": "4.1.10",
    "@tarojs/runtime": "4.1.10",
    "@tarojs/shared": "4.1.10",
    "@tarojs/taro": "4.1.10",
    "immer": "^11.1.3",
    "miaoda-sc-plugin": "1.0.56",
    "miaoda-taro-utils": "0.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "supabase-wechat-js": "0.0.7",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@babel/core": "^7.28.6",
    "@babel/preset-react": "^7.28.5",
    "@biomejs/biome": "2.3.4",
    "@egoist/tailwindcss-icons": "^1.9.0",
    "@iconify-json/lucide": "^1.2.86",
    "@iconify-json/mdi": "^1.2.3",
    "@tarojs/cli": "4.1.10",
    "@tarojs/taro-loader": "4.1.10",
    "@tarojs/vite-runner": "4.1.10",
    "@types/node": "^24.3.0",
    "@types/react": "^18.3.24",
    "@typescript/native-preview": "7.0.0-dev.20260123.3",
    "@vitejs/plugin-react": "^4.7.0",
    "babel-preset-taro": "4.1.10",
    "postcss": "^8.5.6",
    "react-refresh": "^0.18.0",
    "supabase": "^2.83.0",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^4.5.14",
    "weapp-tailwindcss": "^4.9.4"
  },
  "resolutions": {
    "esbuild": "0.21.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "supabase"
    ]
  },
  "packageManager": "pnpm@10.28.1"
}
